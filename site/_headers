# Cache rules for Netlify / Cloudflare Pages. Other hosts ignore this file.
# Content-addressed assets never change under the same name, so they can be cached
# hard; HTML and JSON must stay fresh so edits show up immediately.

/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

/assets/brand/*
  Cache-Control: public, max-age=31536000, immutable

/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/assets/css/*
  Cache-Control: public, max-age=604800

/assets/js/*
  Cache-Control: public, max-age=604800

/data/*
  Cache-Control: public, max-age=3600

/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
